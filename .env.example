# ============================================
# Environment Configuration
# ============================================
NODE_ENV=production
VERSION=1.0.0

# ============================================
# MongoDB Configuration
# ============================================
MONGO_ROOT_USERNAME=your_mongo_root_username
MONGO_ROOT_PASSWORD=your_mongo_root_password
MONGO_DATABASE=your_database_name
TZ=Asia/Jakarta

# ============================================
# Mongo Express Configuration (GUI)
# ============================================
MONGO_EXPRESS_USERNAME=your_admin_username
MONGO_EXPRESS_PASSWORD=your_admin_password

# ============================================
# JWT Configuration (Global)
# ============================================
JWT_SECRET=your_global_jwt_secret_here

# ============================================
# Redis Configuration (Global)
# generate secure value (PowerShell):
#   [Convert]::ToBase64String((1..48 | ForEach-Object { Get-Random -Maximum 256 }))
# generate secure value (Node.js):
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
REDIS_PASSWORD=your_strong_redis_password_here
AUTH_REDIS_STRICT=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# ============================================
# Docker Configuration
# ============================================
COMPOSE_PROJECT_NAME=pt-solusi-bangunan-berkah