{
  "name": "bangunan-berkah-tests",
  "version": "2.0.0",
  "description": "Black-box integration tests for PT Solusi Bangunan Berkah Microservices",
  "private": true,
  "scripts": {
    "test": "mocha --config .mocharc.yml",
    "test:auth": "mocha --no-config --require ./helpers/setup.js --timeout 15000 --exit --recursive \"auth-service/**/*.test.js\"",
    "test:project": "mocha --no-config --require ./helpers/setup.js --timeout 15000 --exit --recursive \"project-service/**/*.test.js\"",
    "test:review": "mocha --no-config --require ./helpers/setup.js --timeout 15000 --exit --recursive \"review-service/**/*.test.js\""
  },
  "dependencies": {
    "chai": "^4.3.10",
    "mocha": "^10.2.0",
    "supertest": "^6.3.3"
  }
}
