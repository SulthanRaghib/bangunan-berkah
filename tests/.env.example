# ============================================
# TEST ENVIRONMENT CONFIGURATION
# ============================================
# Salin file ini menjadi .env lalu sesuaikan nilainya
# cp .env.example .env
#
# Untuk menjalankan test dengan .env, gunakan:
#   npx mocha --config .mocharc.yml
#
# Atau set langsung di terminal:
#   TEST_BASE_URL=http://your-vps:8080 npx mocha

# ============================================
# API Gateway Base URL
# ============================================
# URL target untuk testing (termasuk port)
# Default: http://localhost:8080
TEST_BASE_URL=http://localhost:8080

# ============================================
# Test Credentials (Admin)
# ============================================
# Harus sesuai dengan data dari prisma:seed
# Default: admin123
TEST_ADMIN_PASSWORD=admin123

# ============================================
# Test Credentials (User Biasa)
# ============================================
# Harus sesuai dengan data dari prisma:seed
# Default: admin123
TEST_USER_PASSWORD=admin123
