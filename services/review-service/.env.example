# Server
PORT=8005

# Service
SERVICE_NAME=review-service

# Database
DATABASE_URL=mongodb://admin:password@mongodb:27017/review_db?authSource=admin

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=30d

# Environment
NODE_ENV=development

# Inter-Service Communication
PROJECT_SERVICE_URL=http://project-service:8004

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:8005

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_strong_redis_password_here
REDIS_DB=0
AUTH_REDIS_STRICT=true
AUTH_REDIS_FAIL_CLOSED_PATHS=/api/reviews/admin
AUTH_REDIS_FAIL_OPEN_PATHS=

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
