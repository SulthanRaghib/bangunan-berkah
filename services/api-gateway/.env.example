PORT=8080

AUTH_SERVICE_URL=http://auth-service:8001
PRODUCT_SERVICE_URL=http://product-service:8002
CHAT_SERVICE_URL=http://chat-service:8003
PROJECT_SERVICE_URL=http://project-service:8004
REVIEW_SERVICE_URL=http://review-service:8005

SERVICE_NAME=api-gateway
NODE_ENV=development

# CORS Configuration
# Set FRONTEND_URL to match your frontend domain
FRONTEND_URL=http://localhost:3000

# JWT Secret (MUST match auth-service JWT_SECRET)
# Generate: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# Redis (Distributed Rate Limiting)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_strong_redis_password_here
REDIS_DB=0

# Rate Limiting Policy
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
