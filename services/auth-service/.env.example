# Server
PORT=8001

# Service
SERVICE_NAME=auth-service

# Database
DATABASE_URL=mongodb://admin:password@mongodb:27017/auth_db?authSource=admin

# JWT > generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=yoursupersecretjwtkey
JWT_EXPIRES_IN=7d
# generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# Environment
NODE_ENV=development

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:8001

# Redis (JWT blacklist & refresh token rotation)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_strong_redis_password_here
REDIS_DB=0
AUTH_REDIS_STRICT=true
AUTH_REDIS_FAIL_CLOSED_PATHS=/api/auth/profile,/api/auth/logout,/api/users
AUTH_REDIS_FAIL_OPEN_PATHS=

# Seeder
SEED_PASSWORD=your_default_seed_password
